# FGI V3.8 本地运行环境变量
# Copy to .env and fill in your values

# PushPlus push notification (optional)
# Register at https://www.pushplus.plus to get your token
FGI_PUSHPLUS_TOKEN=

# Data sources (default: all enabled)
# FGI_AKSHARE_ENABLED=true
# FGI_MOOTDX_ENABLED=true
# FGI_TENCENT_ENABLED=true

# Webhook (legacy, for alert module)
# FGI_WEBHOOK_URL=
# FGI_WEBHOOK_TYPE=wecom
